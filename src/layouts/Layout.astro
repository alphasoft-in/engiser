---
import '../styles/global.css';
import WhatsAppButton from '../components/WhatsAppButton';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "ENGISER - Consultoría, ingeniería contra incendios y venta de equipos de rescate de alta calidad." } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
		<link rel="manifest" href="/site.webmanifest">
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Tags -->
		<title>{title} | ENGISER - Ingeniería y Seguridad</title>
		<meta name="description" content={description} />
		<meta name="keywords" content="ingeniería contra incendios, seguridad industrial, salud ocupacional, equipos de rescate, saneamiento ambiental, perú, engiser" />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={Astro.url} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={`${title} | ENGISER`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL('/images/hero.avif', Astro.url)} />
		<meta property="og:locale" content="es_PE" />
		<meta property="og:site_name" content="ENGISER" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={`${title} | ENGISER`} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL('/images/hero.avif', Astro.url)} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		
		<style>
			body {
				font-family: 'Inter', sans-serif;
			}
			h1, h2, h3, h4, h5, h6 {
				font-family: 'Outfit', sans-serif;
			}
		</style>
	</head>
	<body class="bg-[#020205] text-white overflow-x-hidden">
		<slot />
		<WhatsAppButton client:load />
	</body>
</html>
