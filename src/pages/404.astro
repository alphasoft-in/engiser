---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation';
import Footer from '../components/Footer';
import { Home, AlertTriangle, ArrowLeft } from 'lucide-react';
---

<Layout title="404 - Página no encontrada" description="Lo sentimos, la página que estás buscando no existe o ha sido movida.">
	<Navigation client:load />
	
	<main class="relative min-h-screen flex justify-center bg-white overflow-hidden pt-10 md:pt-16">
    {/* Decorative Elements */}
    <div class="absolute top-1/4 -left-20 w-96 h-96 bg-orange-600/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-1/4 -right-20 w-72 h-72 bg-red-600/5 rounded-full blur-[100px]"></div>

		<div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10 py-10 text-center">
      <div class="flex flex-col items-center">
        <div class="mb-2">
          <h1 class="text-[120px] md:text-[180px] font-black font-outfit leading-none text-orange-600 select-none tracking-tighter">
            404
          </h1>
        </div>

        <h2 class="text-3xl md:text-5xl font-black font-outfit mb-6 text-slate-900 tracking-tight uppercase">
          Página no <span class="bg-clip-text text-transparent bg-gradient-to-r from-orange-600 to-red-600">Encontrada</span>
        </h2>

        <p class="text-slate-500 text-lg md:text-xl mb-12 max-w-lg mx-auto font-medium leading-relaxed">
          Lo sentimos, el enlace que has seguido puede estar roto o la página ha sido eliminada.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a 
            href="/" 
            class="inline-flex items-center gap-3 bg-slate-950 text-white px-8 py-4 rounded-full font-bold text-[11px] uppercase tracking-[0.2em] hover:bg-orange-600 transition-all duration-300 group shadow-xl shadow-slate-950/20"
          >
            <Home className="w-4 h-4" />
            Volver al Inicio
          </a>
          
          <button 
            onclick="window.history.back()"
            class="inline-flex items-center gap-3 bg-white text-slate-900 border border-slate-200 px-8 py-4 rounded-full font-bold text-[11px] uppercase tracking-[0.2em] hover:border-orange-600 hover:text-orange-600 transition-all duration-300 group shadow-sm"
          >
            <ArrowLeft className="w-4 h-4" />
            Regresar
          </button>
        </div>
      </div>
		</div>
	</main>

	<Footer />
</Layout>
