---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation';
import PageHeader from '../../components/PageHeader';
import Footer from '../../components/Footer';
import { Droplets } from 'lucide-react';

const mainServices = [
  { 
    name: 'IMPLEMENTACIÓN ISO 14001', 
    image: '/images/ambiental/iso.avif' 
  },
  { 
    name: 'IMPACTO AMBIENTAL', 
    image: '/images/ambiental/impacto.avif' 
  },
  { 
    name: 'MONITOREO DE EMISIONES', 
    image: '/images/ambiental/emisiones.avif' 
  },
  { 
    name: 'GESTIÓN DE RESIDUOS', 
    image: '/images/ambiental/residuos.avif' 
  },
  { 
    name: 'PROGRAMA PAMA', 
    image: '/images/ambiental/pama.avif' 
  },
  { 
    name: 'ANÁLISIS BIOLÓGICO', 
    image: '/images/ambiental/biologico.avif' 
  },
];

const specializedMonitoring = [
  'Monitoreo de Calidad de Suelo',
  'Calidad del Agua y Efluentes',
  'Radiaciones No Ionizantes',
  'Tercerización de Medio Ambiente',
  'Monitoreo de Ruido y Vibraciones',
  'Matrices Ambientales Dinámicas'
];
---

<Layout 
	title="Gestión y Consultoría Ambiental para Empresas"
	description="Servicios especializados en monitoreo ambiental, gestión de residuos sólidos y estudios de impacto ambiental para un cumplimiento normativo sostenible."
>
	<Navigation client:load />
	
	<main class="bg-white min-h-screen">
    <PageHeader title="Gestión Ambiental" currentPage="Ambiental" client:load />

		<section class="py-24 overflow-hidden">
			<div class="max-w-7xl mx-auto px-6 md:px-12">
				{/* Header Section */}
				<div class="max-w-4xl mx-auto text-center mb-20 flex flex-col items-center">
					<div class="flex items-center gap-3 mb-6">
						<div class="w-10 h-[2px] bg-orange-600"></div>
						<h2 class="text-[11px] font-black text-orange-600 uppercase tracking-[0.3em]">Sostenibilidad Industrial</h2>
						<div class="w-10 h-[2px] bg-orange-600"></div>
					</div>

					<h1 class="text-2xl md:text-4xl font-black font-outfit mb-8 leading-tight text-slate-900 tracking-tight uppercase">
						Sistema de <br />
						<span class="bg-clip-text text-transparent bg-gradient-to-r from-orange-600 to-red-600">Gestión Ambiental</span>
					</h1>

					<p class="text-slate-500 text-sm md:text-base leading-relaxed font-medium max-w-2xl mx-auto">
						Colaboramos con su equipo para diseñar, implantar, evaluar y mejorar su Sistema de Gestión Ambiental (SGA) referido a la norma internacional ISO 14001.
					</p>
				</div>

				{/* Ambiental Grid - PREMIUM CIRCLE FORMAT */}
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-16 gap-x-12 relative justify-items-center mb-32">
					{mainServices.map((service) => (
						<div class="flex flex-col items-center group w-full max-w-[280px]">
							<div class="relative w-48 h-48 sm:w-56 sm:h-56 rounded-full border-4 border-orange-600 p-2 bg-white shadow-2xl group-hover:rotate-6 transition-transform duration-500 flex items-center justify-center overflow-hidden">
								<img 
                  src={service.image} 
                  alt={service.name}
                  class="w-full h-full object-cover rounded-full group-hover:scale-110 transition-transform duration-500"
                />
							</div>
							<div class="mt-8 text-slate-900 text-[11px] md:text-[12px] font-black tracking-[0.25em] text-center uppercase group-hover:text-orange-600 transition-colors duration-300">
								{service.name}
                <div class="w-0 h-0.5 bg-orange-600 mx-auto mt-2 group-hover:w-12 transition-all duration-500"></div>
							</div>
						</div>
					))}
					{/* Decorative Background Element */}
					<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-orange-600/5 rounded-full blur-[150px] -z-10" />
				</div>

				{/* Specialized Monitoring Section */}
				<div class="bg-slate-950 rounded-[3rem] p-8 md:p-16 relative overflow-hidden shadow-2xl">
          <div class="absolute top-0 right-0 w-full h-full bg-[url('https://www.transparenttextures.com/patterns/leaf.avif')] opacity-5"></div>
          
          <div class="relative z-10 grid lg:grid-cols-2 gap-16 items-center">
            <div>
              <h3 class="text-white text-3xl font-black uppercase tracking-widest mb-8 leading-tight">
                Control <br />
                <span class="text-orange-600">& Monitoreo</span>
              </h3>
              <p class="text-slate-400 font-medium mb-10 text-sm leading-relaxed max-w-md">
                Contamos con tecnología avanzada para el monitoreo de agentes ambientales, garantizando el cumplimiento de los estándares de calidad nacional e internacional.
              </p>
              <div class="flex items-center gap-4 text-white font-black text-[10px] uppercase tracking-widest">
                <div class="w-12 h-1 bg-orange-600"></div>
                Certificación ISO 14001
              </div>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 w-full">
              {specializedMonitoring.map((item) => (
                <div class="bg-white/5 border border-white/10 p-5 rounded-2xl group hover:border-orange-600 transition-all flex items-center gap-3">
                  <Droplets className="text-orange-600 w-4 h-4 flex-shrink-0" />
                  <span class="text-white font-black text-[10px] uppercase tracking-[0.2em] leading-snug">{item}</span>
                </div>
              ))}
            </div>
          </div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
