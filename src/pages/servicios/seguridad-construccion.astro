---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation';
import PageHeader from '../../components/PageHeader';
import Footer from '../../components/Footer';
import { Microscope as Lab, Accessibility } from 'lucide-react';

const constructionServices = [
  { 
    name: 'MALLAS ANTI CAÍDAS', 
    image: '/images/construccion/mallas.avif' 
  },
  { 
    name: 'BARANDAS DE PROTECCIÓN', 
    image: '/images/construccion/barandas.avif' 
  },
  { 
    name: 'BANDEJAS DE SEGURIDAD', 
    image: '/images/construccion/bandejas.avif' 
  },
  { 
    name: 'ANDAMIOS HOMOLOGADOS', 
    image: '/images/construccion/andamios.avif' 
  },
];

const biologicalAgents = [
  'Análisis Microbiológico en Ambientes',
  'Análisis en Superficies Vivas e Inertes',
  'Calidad de Agua Potable',
  'Análisis en Alimentos Elaborados'
];

const ergonomicAgents = [
  'Evaluación de Posturas Forzadas',
  'Métodos: OWAS, NIOSH, OCRA, ISO',
  'Diseño de Puestos de Trabajo',
  'Evaluación de Empuje y Tracción'
];
---

<Layout 
	title="Seguridad y Salud en Obras de Construcción"
	description="Servicios de prevención de riesgos, supervisión de seguridad y salud en proyectos de edificación y construcción civil bajo normativa nacional G.050."
>
	<Navigation client:load />
	
	<main class="bg-white min-h-screen">
    <PageHeader title="Seguridad Construcción" currentPage="Construcción" client:load />

		<section class="py-24 overflow-hidden">
			<div class="max-w-7xl mx-auto px-6 md:px-12">
				{/* Header Section */}
				<div class="max-w-4xl mx-auto text-center mb-20 flex flex-col items-center">
					<div class="flex items-center gap-3 mb-6">
						<div class="w-10 h-[2px] bg-orange-600"></div>
						<h2 class="text-[11px] font-black text-orange-600 uppercase tracking-[0.3em]">Seguridad Colectiva</h2>
						<div class="w-10 h-[2px] bg-orange-600"></div>
					</div>

					<h1 class="text-2xl md:text-4xl font-black font-outfit mb-8 leading-tight text-slate-900 tracking-tight uppercase">
						Protección y Prevención en <br />
						<span class="bg-clip-text text-transparent bg-gradient-to-r from-orange-600 to-red-600">Obras de Construcción</span>
					</h1>

					<p class="text-slate-500 text-sm md:text-base leading-relaxed font-medium max-w-2xl mx-auto">
						Implementamos sistemas integrales de seguridad para prevenir accidentes y enfermedades laborales en el sector construcción, protegiendo tanto a los trabajadores como a los visitantes.
					</p>
				</div>

				{/* Construction Grid - PREMIUM CIRCLE FORMAT */}
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-y-16 gap-x-8 relative justify-items-center mb-32">
					{constructionServices.map((service) => (
						<div class="flex flex-col items-center group w-full max-w-[240px]">
							<div class="relative w-40 h-40 sm:w-48 sm:h-48 rounded-full border-4 border-orange-600 p-2 bg-white shadow-2xl group-hover:rotate-6 transition-transform duration-500 flex items-center justify-center overflow-hidden">
								<img 
                  src={service.image} 
                  alt={service.name}
                  class="w-full h-full object-cover rounded-full group-hover:scale-110 transition-transform duration-500"
                />
							</div>
							<div class="mt-8 text-slate-900 text-[10px] md:text-[11px] font-black tracking-[0.25em] text-center uppercase group-hover:text-orange-600 transition-colors duration-300">
								{service.name}
                <div class="w-0 h-0.5 bg-orange-600 mx-auto mt-2 group-hover:w-10 transition-all duration-500"></div>
							</div>
						</div>
					))}
					{/* Decorative Background Element */}
					<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-orange-600/5 rounded-full blur-[150px] -z-10" />
				</div>

				{/* Two-Column Section for Lab and Ergonomics */}
				<div class="grid lg:grid-cols-2 gap-8">
          {/* Biological Agents */}
					<div class="bg-slate-950 rounded-[3rem] p-8 md:p-12 relative overflow-hidden shadow-2xl">
            <div class="absolute top-0 right-0 w-32 h-32 bg-orange-600/10 rounded-full blur-3xl"></div>
            <h3 class="text-white text-xl font-black uppercase tracking-widest mb-8 flex items-center gap-4">
              <Lab className="text-orange-600 w-6 h-6" />
              Agentes Biológicos
            </h3>
            <div class="grid gap-4">
              {biologicalAgents.map((item) => (
                <div class="flex items-center gap-4 group">
                  <div class="w-1.5 h-1.5 rounded-full bg-orange-600"></div>
                  <span class="text-slate-300 font-bold text-[10px] uppercase tracking-widest group-hover:text-white transition-colors">{item}</span>
                </div>
              ))}
            </div>
          </div>

          {/* Ergonomic Agents */}
          <div class="bg-slate-50 rounded-[3rem] p-8 md:p-12 border border-slate-100 shadow-xl">
            <h3 class="text-slate-900 text-xl font-black uppercase tracking-widest mb-8 flex items-center gap-4">
              <Accessibility className="text-orange-600 w-6 h-6" />
              Agentes Disergonómicos
            </h3>
            <div class="grid gap-4">
              {ergonomicAgents.map((item) => (
                <div class="flex items-center gap-4 group">
                  <div class="w-1.5 h-1.5 rounded-full bg-slate-900 group-hover:bg-orange-600 transition-colors"></div>
                  <span class="text-slate-600 font-bold text-[10px] uppercase tracking-widest group-hover:text-slate-900 transition-colors">{item}</span>
                </div>
              ))}
            </div>
          </div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
