---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation';
import PageHeader from '../../components/PageHeader';
import Footer from '../../components/Footer';
import { 
  Volume2, 
  Sun, 
  Thermometer, 
  Activity, 
  Wind, 
  FlaskConical,
  ShieldCheck,
  ClipboardCheck,
  Microscope,
  FileSearch,
  Zap,
  Droplets
} from 'lucide-react';

const mainMonitoring = [
  { name: 'RUIDO Y SONOMETRÍA', icon: Volume2, desc: 'Dosimetría y mapas de ruido industrial.' },
  { name: 'ILUMINACIÓN LABORAL', icon: Sun, desc: 'Evaluación de niveles de lux para confort visual.' },
  { name: 'ESTRÉS TÉRMICO', icon: Thermometer, desc: 'Control de temperaturas extremas en planta.' },
  { name: 'CALIDAD DE AIRE', icon: Wind, desc: 'Monitoreo de partículas y polvos respirables.' },
  { name: 'AGENTES QUÍMICOS', icon: FlaskConical, desc: 'Evaluación de gases, vapores y humos metálicos.' },
  { name: 'VIBRACIÓN Y OTROS', icon: Activity, desc: 'Análisis de vibración de cuerpo entero y mano.' },
];

const specializedHigiene = [
  { 
    title: 'Evaluación Ergonómica', 
    desc: 'Métodos OWAS, NIOSH y análisis de posturas forzadas.',
    icon: Activity 
  },
  { 
    title: 'Agentes Biológicos', 
    desc: 'Análisis microbiológico en superficies e infraestructuras.',
    icon: Microscope 
  },
  { 
    title: 'Informes de Auditoría', 
    desc: 'Documentación técnica bajo estándares ISO y Ley 29783.',
    icon: ClipboardCheck 
  },
  { 
    title: 'Protocolos de Salud', 
    desc: 'Diseño de planes preventivos de higiene industrial.',
    icon: ShieldCheck 
  },
  { 
    title: 'Dosimetría Personal', 
    desc: 'Seguimiento individual de exposición a riesgos físicos.',
    icon: Zap 
  },
  { 
    title: 'Vapores y Ácidos', 
    desc: 'Medición de compuestos orgánicos volátiles (COVs).',
    icon: Droplets 
  }
];
---

<Layout title="Monitoreo Ocupacional - ENGISER">
	<Navigation client:load />
	
	<main class="bg-white min-h-screen">
    <PageHeader title="Monitoreo Ocupacional" currentPage="Ocupacional" client:load />

		<section class="py-24 overflow-hidden">
			<div class="max-w-7xl mx-auto px-6 md:px-12">
				{/* Header Section */}
				<div class="max-w-4xl mx-auto text-center mb-20 flex flex-col items-center">
					<div class="flex items-center gap-3 mb-6">
						<div class="w-10 h-[2px] bg-orange-600"></div>
						<h2 class="text-[11px] font-black text-orange-600 uppercase tracking-[0.3em]">Higiene Industrial</h2>
						<div class="w-10 h-[2px] bg-orange-600"></div>
					</div>

					<h1 class="text-2xl md:text-4xl font-black font-outfit mb-8 leading-tight text-slate-900 tracking-tight uppercase">
						Evaluación de <br />
						<span class="bg-clip-text text-transparent bg-gradient-to-r from-orange-600 to-red-600">Agentes Ocupacionales</span>
					</h1>

					<p class="text-slate-500 text-sm md:text-base leading-relaxed font-medium max-w-2xl mx-auto">
						Identificamos y evaluamos los factores de riesgo físico, químico y biológico en el entorno laboral para garantizar la salud y bienestar de sus colaboradores.
					</p>
				</div>

				{/* Monitoreo Grid - PREMIUM CIRCLE FORMAT */}
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-20 gap-x-12 relative justify-items-center mb-32">
					{mainMonitoring.map((item) => (
						<div class="flex flex-col items-center group w-full max-w-[280px]">
							<div class="relative w-48 h-48 sm:w-56 sm:h-56 rounded-full border-4 border-orange-600 p-2 bg-white shadow-2xl group-hover:rotate-6 transition-transform duration-500 flex items-center justify-center overflow-hidden">
								<div class="w-full h-full rounded-full bg-slate-950 flex flex-col items-center justify-center p-8 relative overflow-hidden">
                  {/* Decorative Glow */}
                  <div class="absolute inset-0 bg-gradient-to-br from-orange-600/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                  
                  <item.icon className="text-orange-600 w-16 h-16 mb-4 relative z-10 group-hover:scale-110 transition-transform duration-500" />
                  <p class="text-[9px] text-slate-400 font-bold uppercase tracking-[0.2em] text-center relative z-10 opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-4 group-hover:translate-y-0">
                    {item.desc}
                  </p>
                </div>
							</div>
							<div class="mt-8 text-slate-900 text-[11px] md:text-[12px] font-black tracking-[0.25em] text-center uppercase group-hover:text-orange-600 transition-colors duration-300">
								{item.name}
                <div class="w-0 h-0.5 bg-orange-600 mx-auto mt-2 group-hover:w-12 transition-all duration-500"></div>
							</div>
						</div>
					))}
					{/* Decorative Background Element */}
					<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-orange-600/5 rounded-full blur-[150px] -z-10" />
				</div>

				{/* Higiene Especializada Section - PREMIUM DARK */}
				<div class="bg-slate-950 rounded-[3rem] p-12 md:p-20 relative overflow-hidden shadow-2xl">
          <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-10"></div>
          
          <div class="relative z-10">
            <div class="max-w-2xl mb-16">
              <h3 class="text-white text-3xl font-black uppercase tracking-[0.2em] mb-6 flex items-center gap-6">
                <span class="w-16 h-1 bg-orange-600"></span>
                Consultoría en <br class="hidden md:block" /> Higiene Industrial
              </h3>
              <p class="text-slate-400 font-medium text-sm leading-relaxed uppercase tracking-wider">
                Servicios especializados bajo normativa Ley 29783 y estándares internacionales NIOSH/OSHA.
              </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {specializedHigiene.map((item) => (
                <div class="bg-white/5 border border-white/10 p-8 rounded-[2rem] group hover:bg-orange-600 transition-all duration-500 hover:-translate-y-2 flex flex-col items-start gap-6">
                  <div class="w-14 h-14 bg-white/10 rounded-2xl flex items-center justify-center group-hover:bg-white/20 transition-colors">
                    <item.icon className="text-orange-600 group-hover:text-white w-7 h-7" />
                  </div>
                  <div>
                    <h4 class="text-white font-black text-[11px] uppercase tracking-[0.2em] mb-3 group-hover:text-white">
                      {item.title}
                    </h4>
                    <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest leading-relaxed group-hover:text-white/80">
                      {item.desc}
                    </p>
                  </div>
                </div>
              ))}
              
              {/* Specialized CTA */}
              <div class="bg-slate-900 border-2 border-dashed border-orange-600/30 p-8 rounded-[2rem] flex flex-col justify-center items-center text-center gap-6 group">
                <FileSearch className="text-orange-600 w-12 h-12" />
                <div>
                  <h4 class="text-white font-black text-[11px] uppercase tracking-[0.2em] mb-4">¿Necesitas un Plan de Monitoreo Anual?</h4>
                  <a href="/contacto" class="inline-block bg-orange-600 text-white px-8 py-3 rounded-full text-[10px] font-black uppercase tracking-widest hover:scale-105 transition-all">
                    Solicitar Cotización
                  </a>
                </div>
              </div>
            </div>
          </div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
