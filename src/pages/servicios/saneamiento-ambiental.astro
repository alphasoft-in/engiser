---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation';
import PageHeader from '../../components/PageHeader';
import Footer from '../../components/Footer';
import { 
  Droplets, 
  ShieldCheck, 
  Bug, 
  Wind, 
  Trash2, 
  Sparkles 
} from 'lucide-react';

const sanitationServices = [
  { 
    name: 'DESINSECTACIÓN', 
    image: '/images/saneamiento/pest.avif' 
  },
  { 
    name: 'DESRATIZACIÓN', 
    image: '/images/saneamiento/rat.avif' 
  },
  { 
    name: 'DESINFECCIÓN', 
    image: '/images/saneamiento/disinfection.avif' 
  },
  { 
    name: 'LIMPIEZA DE TANQUES', 
    image: '/images/saneamiento/tank.avif' 
  },
  { 
    name: 'GESTIÓN DE RESIDUOS', 
    image: '/images/saneamiento/waste.avif' 
  },
  { 
    name: 'CALIDAD DE AIRE', 
    image: '/images/saneamiento/air.avif' 
  },
];
---

<Layout 
	title="Saneamiento Ambiental y Control de Plagas"
	description="Servicios profesionales de desinsectación, desratización y desinfección de ambientes. Especialistas en eliminación de plagas para empresas y hogares."
>
	<Navigation client:load />
	
	<main class="bg-white min-h-screen">
    <PageHeader title="Saneamiento Ambiental" currentPage="Saneamiento" client:load />

		<section class="pt-12 md:pt-10 pb-12 md:pb-10 overflow-hidden">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-6 lg:px-12">
				{/* Header Section */}
				<div class="max-w-4xl mx-auto text-center mb-6 md:mb-8 flex flex-col items-center">
					<div class="flex items-center gap-3 mb-6">
						<div class="w-10 h-[2px] bg-orange-600"></div>
						<h2 class="text-[11px] font-black text-orange-600 uppercase tracking-[0.3em]">Ambientes Saludables</h2>
						<div class="w-10 h-[2px] bg-orange-600"></div>
					</div>

					<h1 class="text-xl sm:text-2xl md:text-3xl font-extrabold font-outfit mb-6 leading-[1.1] text-slate-900 tracking-tight">
						Saneamiento <br />
						<span class="text-gradient">Ambiental Integral</span>
					</h1>

					<p class="text-slate-500 text-sm sm:text-base lg:text-lg leading-relaxed font-medium max-w-2xl mx-auto">
						Estamos para ayudarte a eliminar y erradicar todo tipo de plaga, logrando un entorno limpio y saludable para tu empresa y hogar.
					</p>
				</div>

				{/* Hero Image Section */}
				<div class="mb-10 md:mb-12 relative group">
					<div class="relative rounded-[2rem] overflow-hidden border-4 md:border-8 border-white bg-slate-950">
						<img 
							src="/images/saneamiento/hero.avif" 
							alt="Saneamiento Ambiental y Control de Plagas" 
							class="w-full h-[300px] md:h-[400px] lg:h-[600px] object-cover"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/20 md:via-slate-950/40 to-transparent p-6 sm:p-8 md:p-12 flex flex-col justify-end">
							<div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
								<div class="max-w-xl">
									<h3 class="text-white text-lg md:text-xl lg:text-3xl font-extrabold font-outfit mb-4 tracking-tight">Garantía de Salubridad</h3>
									<p class="text-slate-300 font-medium text-[13px] md:text-[12px] lg:text-[13px] leading-relaxed">
										Utilizamos productos autorizados y técnicas avanzadas para asegurar la eliminación de agentes contaminantes sin poner en riesgo la salud.
									</p>
								</div>
								<div class="bg-orange-600 px-5 py-4 sm:px-8 sm:py-8 rounded-xl flex flex-row items-center gap-4 text-left self-start md:self-auto">
									<div class="text-white text-2xl sm:text-4xl font-black">DIGESA</div>
									<div class="text-white/80 text-[9px] sm:text-[10px] font-semibold uppercase tracking-widest leading-tight">Certificación<br /> Oficial</div>
								</div>
							</div>
						</div>
					</div>
				</div>

				{/* Services Grid - PREMIUM CIRCLE FORMAT */}
				<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-y-8 md:gap-y-10 lg:gap-y-16 gap-x-6 lg:gap-x-12 relative justify-items-center mb-6 md:mb-10">
					{sanitationServices.map((service) => (
						<div class="flex flex-col items-center group w-full max-w-[280px]">
							<div class="relative w-40 h-40 sm:w-48 md:w-44 lg:w-56 sm:h-48 md:h-44 lg:h-56 rounded-full border-4 border-orange-600 p-2 bg-white shadow-2xl group-hover:rotate-6 transition-transform duration-500 flex items-center justify-center overflow-hidden">
								<img 
                  src={service.image} 
                  alt={service.name}
                  class="w-full h-full object-cover rounded-full group-hover:scale-110 transition-transform duration-500"
                />
							</div>
							<div class="mt-4 sm:mt-8 text-slate-900 text-[10px] md:text-[11px] lg:text-[12px] font-black tracking-[0.25em] text-center uppercase group-hover:text-orange-600 transition-colors duration-300">
								{service.name}
                <div class="w-0 h-0.5 bg-orange-600 mx-auto mt-2 group-hover:w-12 transition-all duration-500"></div>
							</div>
						</div>
					))}
					{/* Decorative Background Element */}
					<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-orange-600/5 rounded-full blur-[150px] -z-10" />
				</div>

				{/* CTA Section */}
				<div class="mt-12 bg-slate-950 rounded-[2rem] px-6 py-10 md:px-8 md:py-12 lg:p-20 relative overflow-hidden shadow-2xl text-center">
					<div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.avif')] opacity-10"></div>
					<div class="relative z-10 flex flex-col items-center">
						<h3 class="text-white text-xl md:text-2xl lg:text-5xl font-extrabold font-outfit mb-8 leading-[1.1] tracking-tight">
							¿Problemas de <span class="text-orange-600">plagas en tu local?</span>
						</h3>
						<p class="text-slate-400 font-medium text-base md:text-[13px] lg:text-base mb-12 max-w-2xl mx-auto">
							Realizamos inspecciones gratuitas y diseñamos un plan de saneamiento a medida para cumplir con todas las normativas de salud vigentes.
						</p>
						<a 
							href="https://wa.me/51950267871?text=Hola,%20necesito%20una%20inspección%20de%20saneamiento%20ambiental%20para%20mi%20local." 
							target="_blank"
							rel="noopener noreferrer"
							class="bg-orange-600 text-white px-8 py-3 rounded-full text-[10px] font-black uppercase tracking-[0.2em] hover:scale-105 hover:bg-orange-500 transition-all shadow-xl shadow-orange-600/20"
						>
							Consultar en WhatsApp
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
