---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation';
import PageHeader from '../../components/PageHeader';
import Footer from '../../components/Footer';
import { 
  ShieldCheck, 
  Search, 
  Globe, 
  Droplets, 
  Mountain, 
  FileCheck, 
  AlertTriangle 
} from 'lucide-react';

const sstServices = [
  { 
    name: 'AUDITORÍAS DE GESTIÓN', 
    image: '/images/sst/audit.avif' 
  },
  { 
    name: 'IMPLEMENTACIÓN SST', 
    image: '/images/sst/implementation.avif' 
  },
  { 
    name: 'SISTEMAS INTEGRADOS', 
    image: '/images/sst/integrated.avif' 
  },
  { 
    name: 'PLANES DE CONTINGENCIA', 
    image: '/images/sst/contingency.avif' 
  },
  { 
    name: 'SEGURIDAD EN OBRA', 
    image: '/images/sst/site_safety.avif' 
  },
  { 
    name: 'CAPACITACIONES', 
    image: '/images/sst/training.avif' 
  },
];

const specializedConsultancy = [
  { 
    title: 'Detección de Vulnerabilidades', 
    desc: 'Análisis profundo de riesgos y puntos críticos.',
    icon: Search 
  },
  { 
    title: 'Supervisión Medio Ambiente', 
    desc: 'Control estricto de salud ocupacional y ambiental.',
    icon: Globe 
  },
  { 
    title: 'Certificación BASC', 
    desc: 'Consultoría experta para comercio seguro.',
    icon: ShieldCheck 
  },
  { 
    title: 'Seguridad e Higiene', 
    desc: 'Protocolos industriales de alta eficiencia.',
    icon: Droplets 
  },
  { 
    title: 'Ley Minera D.S. 050-EM', 
    desc: 'Cumplimiento normativo especializado en minería.',
    icon: Mountain 
  },
  { 
    title: 'Homologaciones Técnicas', 
    desc: 'Validación de estándares para proveedores.',
    icon: FileCheck 
  },
  { 
    title: 'Prevención de Riesgos', 
    desc: 'Cultura de seguridad y reducción de incidentes.',
    icon: AlertTriangle 
  }
];
---

<Layout 
	title="Consultoría en Seguridad y Salud Ocupacional"
	description="Asesoría integral en la implementación del Sistema de Gestión de Seguridad y Salud en el Trabajo (SGSST) según la Ley 29783 y auditorías especializadas."
>
	<Navigation client:load />
	
	<main class="bg-white min-h-screen">
    <PageHeader title="Seguridad y Salud" currentPage="SST" client:load />

		<section class="py-24 overflow-hidden">
			<div class="max-w-7xl mx-auto px-6 md:px-12">
				{/* Header Section */}
				<div class="max-w-4xl mx-auto text-center mb-20 flex flex-col items-center">
					<div class="flex items-center gap-3 mb-6">
						<div class="w-10 h-[2px] bg-orange-600"></div>
						<h2 class="text-[11px] font-black text-orange-600 uppercase tracking-[0.3em]">Marco Legal Peruano</h2>
						<div class="w-10 h-[2px] bg-orange-600"></div>
					</div>

					<h1 class="text-2xl md:text-4xl font-black font-outfit mb-8 leading-tight text-slate-900 tracking-tight uppercase">
						Seguridad y Salud en el Trabajo <br />
						<span class="bg-clip-text text-transparent bg-gradient-to-r from-orange-600 to-red-600">Ley 29783</span>
					</h1>

					<p class="text-slate-500 text-sm md:text-base leading-relaxed font-medium max-w-2xl mx-auto">
						Somos una Empresa Consultora líder en el Perú. Utilizamos nuestra experiencia y conocimiento del Marco Legal Peruano para brindar el mejor asesoramiento e implementación de sistemas.
					</p>
				</div>

				{/* SST Grid - PREMIUM CIRCLE FORMAT */}
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-16 gap-x-12 relative justify-items-center mb-32">
					{sstServices.map((service) => (
						<div class="flex flex-col items-center group w-full max-w-[280px]">
							<div class="relative w-48 h-48 sm:w-56 sm:h-56 rounded-full border-4 border-orange-600 p-2 bg-white shadow-2xl group-hover:rotate-6 transition-transform duration-500 flex items-center justify-center overflow-hidden">
								<img 
                  src={service.image} 
                  alt={service.name}
                  class="w-full h-full object-cover rounded-full group-hover:scale-110 transition-transform duration-500"
                />
							</div>
							<div class="mt-8 text-slate-900 text-[11px] md:text-[12px] font-black tracking-[0.25em] text-center uppercase group-hover:text-orange-600 transition-colors duration-300">
								{service.name}
                <div class="w-0 h-0.5 bg-orange-600 mx-auto mt-2 group-hover:w-12 transition-all duration-500"></div>
							</div>
						</div>
					))}
					{/* Decorative Background Element */}
					<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-orange-600/5 rounded-full blur-[150px] -z-10" />
				</div>

				{/* Specialized List Section - REDESIGNED PREMIUM */}
				<div class="bg-slate-950 rounded-[3rem] p-12 md:p-20 relative overflow-hidden shadow-2xl">
          <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.avif')] opacity-10"></div>
          <div class="absolute top-0 right-0 w-96 h-96 bg-orange-600/10 rounded-full blur-[120px] -mr-48 -mt-48"></div>
          
          <div class="relative z-10">
            <div class="max-w-2xl mb-16">
              <h3 class="text-white text-3xl font-black uppercase tracking-[0.2em] mb-6 flex items-center gap-6">
                <span class="w-16 h-1 bg-orange-600"></span>
                Consultoría <br class="hidden md:block" /> Especializada
              </h3>
              <p class="text-slate-400 font-medium text-sm leading-relaxed uppercase tracking-wider">
                Soluciones de alto impacto normativo y técnico para la gran industria.
              </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {specializedConsultancy.map((item) => (
                <div class="bg-white/5 border border-white/10 p-8 rounded-[2rem] group hover:bg-orange-600 transition-all duration-500 hover:-translate-y-2 flex flex-col items-start gap-6">
                  <div class="w-14 h-14 bg-white/10 rounded-2xl flex items-center justify-center group-hover:bg-white/20 transition-colors">
                    <item.icon className="text-orange-600 group-hover:text-white w-7 h-7" />
                  </div>
                  <div>
                    <h4 class="text-white font-black text-[11px] uppercase tracking-[0.2em] mb-3 group-hover:text-white">
                      {item.title}
                    </h4>
                    <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest leading-relaxed group-hover:text-white/80">
                      {item.desc}
                    </p>
                  </div>
                </div>
              ))}
              
              {/* Decorative CTA Box */}
              <div class="bg-orange-600 p-8 rounded-[2rem] flex flex-col justify-center items-center text-center gap-4 group cursor-pointer overflow-hidden relative">
                <div class="absolute inset-0 bg-black opacity-0 group-hover:opacity-10 transition-opacity"></div>
                <h4 class="text-white font-black text-[13px] uppercase tracking-[0.2em] relative z-10">¿Necesitas asesoría personalizada?</h4>
                <a href="/contacto" class="bg-white text-orange-600 px-6 py-2 rounded-full text-[10px] font-black uppercase tracking-widest hover:scale-105 transition-transform relative z-10">
                  Contáctanos
                </a>
              </div>
            </div>
          </div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
