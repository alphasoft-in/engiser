---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation';
import PageHeader from '../../components/PageHeader';
import Footer from '../../components/Footer';
import { ShieldAlert } from 'lucide-react';

const mainServices = [
  { 
    name: 'ANÁLISIS Y DISEÑO', 
    image: '/images/redes/design.png' 
  },
  { 
    name: 'INSTALACIÓN INTEGRAL', 
    image: '/images/redes/installation.png' 
  },
  { 
    name: 'EQUIPOS DE BOMBAS', 
    image: '/images/redes/pumps.png' 
  },
  { 
    name: 'ROCIADORES AUTOMÁTICOS', 
    image: '/images/redes/sprinklers.png' 
  },
  { 
    name: 'SISTEMAS DE ESPUMA', 
    image: '/images/redes/foam.png' 
  },
  { 
    name: 'MANTENIMIENTO NFPA 25', 
    image: '/images/redes/maintenance.png' 
  },
];

const specializedSystems = [
  'Red de Hidrantes y Gabinetes',
  'Sistemas de Extinción con Gas',
  'Extinción para Campanas de Cocina',
  'Sistemas de Pre-acción y Diluvio',
  'Mantenimiento Correctivo 24/7',
  'Venta de Suministros Especializados'
];

const standards = ['NFPA 25', 'NFPA 20', 'NFPA 72', 'NFPA 13', 'NFPA 11'];
---

<Layout title="Redes Contra Incendios - ENGISER">
	<Navigation client:load />
	
	<main class="bg-white min-h-screen">
    <PageHeader title="Redes Contra Incendios" currentPage="Redes" client:load />

		<section class="py-24 overflow-hidden">
			<div class="max-w-7xl mx-auto px-6 md:px-12">
				{/* Header Section */}
				<div class="max-w-4xl mx-auto text-center mb-20 flex flex-col items-center">
					<div class="flex items-center gap-3 mb-6">
						<div class="w-10 h-[2px] bg-orange-600"></div>
						<h2 class="text-[11px] font-black text-orange-600 uppercase tracking-[0.3em]">Ingeniería Hidráulica</h2>
						<div class="w-10 h-[2px] bg-orange-600"></div>
					</div>

					<h1 class="text-2xl md:text-4xl font-black font-outfit mb-8 leading-tight text-slate-900 tracking-tight uppercase">
						Diseño e Instalación de <br />
						<span class="bg-clip-text text-transparent bg-gradient-to-r from-orange-600 to-red-600">Redes Contra Incendios</span>
					</h1>

					<p class="text-slate-500 text-sm md:text-base leading-relaxed font-medium max-w-2xl mx-auto">
						Expertos en instalación, pruebas de funcionalidad y mantenimiento de sistemas contra incendio. Operamos bajo los más estrictos estándares internacionales NFPA.
					</p>

          <div class="flex flex-wrap justify-center gap-4 mt-8">
            {standards.map((s) => (
              <span class="px-4 py-1.5 bg-slate-100 text-slate-900 text-[10px] font-black rounded-full tracking-[0.2em] border border-slate-200">{s}</span>
            ))}
          </div>
				</div>

				{/* Redes Grid - PREMIUM CIRCLE FORMAT */}
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-16 gap-x-12 relative justify-items-center mb-32">
					{mainServices.map((service) => (
						<div class="flex flex-col items-center group w-full max-w-[280px]">
							<div class="relative w-48 h-48 sm:w-56 sm:h-56 rounded-full border-4 border-orange-600 p-2 bg-white shadow-2xl group-hover:rotate-6 transition-transform duration-500 flex items-center justify-center overflow-hidden">
								<img 
                  src={service.image} 
                  alt={service.name}
                  class="w-full h-full object-cover rounded-full group-hover:scale-110 transition-transform duration-500"
                />
							</div>
							<div class="mt-8 text-slate-900 text-[11px] md:text-[12px] font-black tracking-[0.25em] text-center uppercase group-hover:text-orange-600 transition-colors duration-300">
								{service.name}
                <div class="w-0 h-0.5 bg-orange-600 mx-auto mt-2 group-hover:w-12 transition-all duration-500"></div>
							</div>
						</div>
					))}
					{/* Decorative Background Element */}
					<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-orange-600/5 rounded-full blur-[150px] -z-10" />
				</div>

				{/* Specialized Systems Section */}
				<div class="bg-slate-950 rounded-[3rem] p-8 md:p-16 relative overflow-hidden shadow-2xl">
          <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/dark-matter.png')] opacity-20"></div>
          
          <div class="relative z-10 grid lg:grid-cols-2 gap-16 items-center">
            <div>
              <h3 class="text-white text-2xl font-black uppercase tracking-widest mb-8 leading-tight">
                Sistemas <br />
                <span class="text-orange-600">& Riesgos Especiales</span>
              </h3>
              <p class="text-slate-400 font-medium mb-10 text-sm leading-relaxed max-w-md">
                Brindamos soluciones de extinción para entornos críticos: desde campanas de cocina comerciales hasta sistemas de gas para centros de datos y redes de hidratantes industriales.
              </p>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center">
                  <ShieldAlert className="text-orange-600 w-6 h-6" />
                </div>
                <span class="text-white font-black text-[10px] uppercase tracking-[0.2em]">Protección Integral 24/7</span>
              </div>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 w-full">
              {specializedSystems.map((item) => (
                <div class="bg-white/5 border border-white/10 p-5 rounded-2xl group hover:border-orange-600 transition-all">
                  <div class="flex items-center gap-3">
                    <div class="w-1.5 h-1.5 rounded-full bg-orange-600"></div>
                    <span class="text-white font-black text-[10px] uppercase tracking-[0.2em] leading-snug">{item}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
