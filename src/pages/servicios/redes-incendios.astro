---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation';
import PageHeader from '../../components/PageHeader';
import Footer from '../../components/Footer';
import { ShieldAlert } from 'lucide-react';

const mainServices = [
  { 
    name: 'ANÁLISIS Y DISEÑO', 
    image: '/images/redes/design.avif' 
  },
  { 
    name: 'INSTALACIÓN INTEGRAL', 
    image: '/images/redes/installation.avif' 
  },
  { 
    name: 'EQUIPOS DE BOMBAS', 
    image: '/images/redes/pumps.avif' 
  },
  { 
    name: 'ROCIADORES AUTOMÁTICOS', 
    image: '/images/redes/sprinklers.avif' 
  },
  { 
    name: 'SISTEMAS DE ESPUMA', 
    image: '/images/redes/foam.avif' 
  },
  { 
    name: 'MANTENIMIENTO NFPA 25', 
    image: '/images/redes/maintenance.avif' 
  },
];

const specializedSystems = [
  'Red de Hidrantes y Gabinetes',
  'Sistemas de Extinción con Gas',
  'Extinción para Campanas de Cocina',
  'Sistemas de Pre-acción y Diluvio',
  'Mantenimiento Correctivo 24/7',
  'Venta de Suministros Especializados'
];

const standards = ['NFPA 25', 'NFPA 20', 'NFPA 72', 'NFPA 13', 'NFPA 11'];
---

<Layout 
	title="Ingeniería y Redes Contra Incendios"
	description="Diseño, instalación y mantenimiento de sistemas de rociadores, redes de hidrantes y bombas contra incendio bajo normativa nacional e internacional NFPA."
>
	<Navigation client:load />
	
	<main class="bg-white min-h-screen">
    <PageHeader title="Redes Contra Incendios" currentPage="Redes" client:load />

		<section class="pt-12 md:pt-10 pb-12 md:pb-10 overflow-hidden">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-6 lg:px-12">
				{/* Header Section */}
				<div class="max-w-4xl mx-auto text-center mb-10 md:mb-12 flex flex-col items-center">
					<div class="flex items-center gap-3 mb-6">
						<div class="w-10 h-[2px] bg-orange-600"></div>
						<h2 class="text-[11px] font-black text-orange-600 uppercase tracking-[0.3em]">Ingeniería Hidráulica</h2>
						<div class="w-10 h-[2px] bg-orange-600"></div>
					</div>

					<h1 class="text-xl sm:text-2xl md:text-3xl font-extrabold font-outfit mb-6 leading-[1.1] text-slate-900 tracking-tight">
						Diseño e Instalación de <br />
						<span class="text-gradient">Redes Contra Incendios</span>
					</h1>

					<p class="text-slate-500 text-sm sm:text-base lg:text-lg leading-relaxed font-medium max-w-2xl mx-auto">
						Expertos en instalación, pruebas de funcionalidad y mantenimiento de sistemas contra incendio. Operamos bajo los más estrictos estándares internacionales NFPA.
					</p>

          <div class="flex flex-wrap justify-center gap-4 mt-8">
            {standards.map((s) => (
              <span class="px-4 py-1.5 bg-slate-100 text-slate-900 text-[10px] font-black rounded-full tracking-[0.2em] border border-slate-200">{s}</span>
            ))}
          </div>
				</div>

				{/* Redes Grid - PREMIUM CIRCLE FORMAT */}
				<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-y-8 md:gap-y-10 lg:gap-y-16 gap-x-6 lg:gap-x-12 relative justify-items-center mb-6 md:mb-10">
					{mainServices.map((service) => (
						<div class="flex flex-col items-center group w-full max-w-[280px]">
							<div class="relative w-40 h-40 sm:w-48 md:w-44 lg:w-56 sm:h-48 md:h-44 lg:h-56 rounded-full border-4 border-orange-600 p-2 bg-white shadow-2xl group-hover:rotate-6 transition-transform duration-500 flex items-center justify-center overflow-hidden">
								<img 
                  src={service.image} 
                  alt={service.name}
                  class="w-full h-full object-cover rounded-full group-hover:scale-110 transition-transform duration-500"
                />
							</div>
							<div class="mt-4 sm:mt-8 text-slate-900 text-[11px] md:text-[12px] font-black tracking-[0.25em] text-center uppercase group-hover:text-orange-600 transition-colors duration-300">
								{service.name}
                <div class="w-0 h-0.5 bg-orange-600 mx-auto mt-2 group-hover:w-12 transition-all duration-500"></div>
							</div>
						</div>
					))}
					{/* Decorative Background Element */}
					<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-orange-600/5 rounded-full blur-[150px] -z-10" />
				</div>

				{/* Specialized Systems Section */}
				<div class="bg-slate-950 rounded-[2rem] px-6 py-10 md:px-8 md:py-12 lg:p-16 relative overflow-hidden shadow-2xl">
          <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/dark-matter.avif')] opacity-20"></div>
          
          <div class="relative z-10 grid lg:grid-cols-2 gap-6 lg:gap-16 items-center">
            <div>
              <h3 class="text-white text-lg md:text-xl lg:text-3xl font-extrabold font-outfit mb-4 md:mb-6 leading-[1.1] tracking-tight">
                Sistemas <br />
                <span class="text-orange-600">& Riesgos Especiales</span>
              </h3>
               <p class="text-slate-400 font-medium mb-4 text-[13px] md:text-[12px] lg:text-[13px] leading-relaxed max-w-md">
                Brindamos soluciones de extinción para entornos críticos: desde campanas de cocina comerciales hasta sistemas de gas para centros de datos y redes de hidratantes industriales.
              </p>
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center">
                  <ShieldAlert className="text-orange-600 w-5 h-5" />
                </div>
                <span class="text-white font-semibold text-[10px] uppercase tracking-widest">Protección Integral 24/7</span>
              </div>
            </div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 w-full">
              {specializedSystems.map((item) => (
                <div class="bg-white/5 border border-white/10 px-4 py-3 rounded-xl group hover:border-orange-600 transition-all">
                  <div class="flex items-center gap-3">
                    <div class="w-1.5 h-1.5 rounded-full bg-orange-600"></div>
                     <span class="text-white font-semibold text-[8px] md:text-[8.5px] lg:text-[9px] uppercase tracking-widest leading-tight">{item}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
